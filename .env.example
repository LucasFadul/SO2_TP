HIPS_PROJECT_NAME=sentinel_hips
HIPS_ENV=development

# PostgreSQL
HIPS_DB_HOST=localhost
HIPS_DB_PORT=5432
HIPS_DB_NAME=hips
HIPS_DB_USER=hips_app
HIPS_DB_PASSWORD=change_me

# Logs
HIPS_LOG_DIR=/var/log/hips

# Detection thresholds
HIPS_FAILED_LOGIN_LIMIT=5
HIPS_FAILED_LOGIN_WINDOW_MINUTES=10
HIPS_HTTP_404_LIMIT=30
HIPS_HTTP_404_WINDOW_MINUTES=5
HIPS_CPU_LIMIT_PERCENT=90
HIPS_MEMORY_LIMIT_PERCENT=90
HIPS_MAIL_QUEUE_LIMIT=100

# Prevention
HIPS_PREVENTION_DRY_RUN=true
HIPS_BLOCK_DURATION_MINUTES=30

# Email alerts
HIPS_SMTP_HOST=localhost
HIPS_SMTP_PORT=25
HIPS_ALERT_FROM=hips@localhost
HIPS_ALERT_TO=admin@localhost

